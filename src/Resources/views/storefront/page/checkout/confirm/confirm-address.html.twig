{% sw_extends '@Storefront/storefront/page/checkout/confirm/confirm-address.html.twig' %}

{% block page_checkout_confirm_address_shipping_actions %}
    {{ parent() }}

    {% set requiredShippingMethodIds = config('KeszlerShippingPhoneRequirement.config.shippingMethodsRequiringPhoneNumber') ?? [] %}
    {% set phoneRequired = requiredShippingMethodIds is iterable and context.shippingMethod is defined and context.shippingMethod.id in requiredShippingMethodIds %}
    {% set phoneNumber = shippingAddress.phoneNumber ?? '' %}
    {% set phoneHasDigit = phoneNumber matches '/\\d/' %}
    {% set phoneMissing = phoneRequired and (phoneNumber is empty) %}
    {% set phoneInvalid = phoneRequired and (not phoneMissing) and (not phoneHasDigit) %}
    {% set labelSnippet = config('KeszlerShippingPhoneRequirement.config.phoneNumberLabelSnippet') %}
    {% if labelSnippet is not string or labelSnippet is empty %}
        {% set labelSnippet = 'keszlerShippingPhoneRequirement.phoneNumberLabelPhone' %}
    {% endif %}
    {% set labelText = labelSnippet|trans|sw_sanitize %}

    {% if phoneMissing or phoneInvalid %}
        <div class="mt-3">
            <p class="text-danger mb-2">
                {% if phoneInvalid %}
                    {{ 'checkout.phoneNumberInvalidForShippingMethod'|trans({'%label%': labelText})|sw_sanitize }}
                {% else %}
                    {{ 'checkout.phoneNumberRequiredForShippingMethod'|trans({'%label%': labelText})|sw_sanitize }}
                {% endif %}
            </p>
            <form action="{{ path('frontend.checkout.phone-number.update') }}" method="post">
                {% sw_include '@Storefront/storefront/component/form/form-input.html.twig' with {
                    label: labelSnippet|trans|sw_sanitize,
                    id: 'checkoutPhoneNumberRequired',
                    name: 'phoneNumber',
                    value: phoneNumber,
                    validationRules: 'required',
                    additionalClass: 'mb-2',
                } %}

                <button type="submit" class="btn btn-primary btn-sm">
                    {{ 'checkout.phoneNumberSave'|trans|sw_sanitize }}
                </button>
            </form>
        </div>
    {% endif %}
{% endblock %}
