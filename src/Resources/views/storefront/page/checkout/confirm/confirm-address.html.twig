{% sw_extends '@Storefront/storefront/page/checkout/confirm/confirm-address.html.twig' %}

{% block page_checkout_confirm_address_shipping_actions %}
    {{ parent() }}

    {% set requiredShippingMethodIds = config('KeszlerShippingPhoneRequirement.config.shippingMethodsRequiringPhoneNumber') ?? [] %}
    {% set phoneRequired = requiredShippingMethodIds is iterable and context.shippingMethod is defined and context.shippingMethod.id in requiredShippingMethodIds %}
    {% set phoneMissing = phoneRequired and (shippingAddress.phoneNumber is empty) %}

    {% if phoneMissing %}
        <div class="mt-3">
            <p class="text-danger mb-2">
                {{ 'checkout.phoneNumberRequiredForShippingMethod'|trans|sw_sanitize }}
            </p>
            <form action="{{ path('frontend.checkout.phone-number.update') }}" method="post">
                {% sw_include '@Storefront/storefront/component/form/form-input.html.twig' with {
                    label: 'address.phoneNumberLabel'|trans|sw_sanitize,
                    id: 'checkoutPhoneNumberRequired',
                    name: 'phoneNumber',
                    value: shippingAddress.phoneNumber,
                    validationRules: 'required',
                    additionalClass: 'mb-2',
                } %}

                <button type="submit" class="btn btn-primary btn-sm">
                    {{ 'checkout.addressSaveChange'|trans|sw_sanitize }}
                </button>
            </form>
        </div>
    {% endif %}
{% endblock %}
