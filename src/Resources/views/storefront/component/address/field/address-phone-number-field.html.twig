{% sw_extends '@Storefront/storefront/component/address/field/address-phone-number-field.html.twig' %}

{% block component_address_field_phone_number %}
    {% if formViolations.getViolations('/phoneNumber') is not empty %}
        {% set violationPath = '/phoneNumber' %}
    {% elseif formViolations.getViolations("/#{prefix}/phoneNumber") is not empty %}
        {% set violationPath = "/#{prefix}/phoneNumber" %}
    {% endif %}

    {% set phoneAutocomplete = 'tel' %}

    {% if prefix == 'shippingAddress' %}
        {% set phoneAutocomplete = 'shipping tel' %}
    {% elseif prefix == 'billingAddress' %}
        {% set phoneAutocomplete = 'billing tel' %}
    {% endif %}

    {% set phoneRequired = config('core.loginRegistration.phoneNumberFieldRequired') ? true : false %}
    {% set requiredShippingMethodIds = config('KeszlerShippingPhoneRequirement.config.shippingMethodsRequiringPhoneNumber') ?? [] %}
    {% if requiredShippingMethodIds is iterable and context.shippingMethod is defined and context.shippingMethod.id in requiredShippingMethodIds %}
        {% set phoneRequired = true %}
    {% endif %}

    {% set labelSnippet = config('KeszlerShippingPhoneRequirement.config.phoneNumberLabelSnippet') %}
    {% if labelSnippet is not string or labelSnippet is empty %}
        {% set labelSnippet = 'keszlerShippingPhoneRequirement.phoneNumberLabelPhone' %}
    {% endif %}

    {% sw_include '@Storefront/storefront/component/form/form-input.html.twig' with {
        label: labelSnippet|trans|sw_sanitize,
        id: idPrefix ~ prefix ~ 'AddressPhoneNumber',
        name: prefix ~ '[phoneNumber]',
        value: data.get('phoneNumber'),
        autocomplete: phoneAutocomplete,
        violationPath: violationPath,
        validationRules: phoneRequired ? 'required' : '',
        additionalClass: additionalClass ?? 'col-md-6',
    } %}
{% endblock %}
