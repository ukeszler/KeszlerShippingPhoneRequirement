<?xml version="1.0" encoding="UTF-8"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>Phone number requirement</title>
        <title lang="de-DE">Telefonnummer-Pflicht</title>

        <component name="sw-entity-multi-id-select">
            <name>shippingMethodsRequiringPhoneNumber</name>
            <label>Shipping methods requiring a phone number</label>
            <label lang="de-DE">Versandarten mit Telefonnummer-Pflicht</label>
            <helpText>Only these shipping methods require a phone number during registration and checkout.</helpText>
            <helpText lang="de-DE">Nur diese Versandarten erfordern eine Telefonnummer bei Registrierung und Checkout.</helpText>
            <placeholder>Select shipping methods</placeholder>
            <placeholder lang="de-DE">Versandarten auswählen</placeholder>
            <entity>shipping_method</entity>
            <labelProperty>name</labelProperty>
        </component>

        <input-field type="single-select">
            <name>phoneNumberLabelSnippet</name>
            <label>Phone number label</label>
            <label lang="de-DE">Bezeichnung des Telefonnummer-Feldes</label>
            <helpText>Select which label should be shown for the phone number field.</helpText>
            <helpText lang="de-DE">Wählen Sie, welche Bezeichnung für das Telefonnummer-Feld angezeigt werden soll.</helpText>
            <defaultValue>keszlerShippingPhoneRequirement.phoneNumberLabelPhone</defaultValue>
            <options>
                <option>
                    <id>keszlerShippingPhoneRequirement.phoneNumberLabelPhone</id>
                    <name>Telephone number</name>
                    <name lang="de-DE">Telefonnummer</name>
                </option>
                <option>
                    <id>keszlerShippingPhoneRequirement.phoneNumberLabelMobile</id>
                    <name>Mobile number</name>
                    <name lang="de-DE">Handynummer</name>
                </option>
            </options>
        </input-field>
    </card>
</config>
