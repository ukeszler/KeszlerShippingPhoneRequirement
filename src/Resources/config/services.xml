<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="KeszlerShippingPhoneRequirement\Service\ShippingMethodPhoneRequirement" autowire="true" />
        <service id="KeszlerShippingPhoneRequirement\Service\PhoneNumberValidator" autowire="true" />

        <service id="KeszlerShippingPhoneRequirement\SalesChannel\RegisterRouteDecorator"
                 decorates="Shopware\Core\Checkout\Customer\SalesChannel\RegisterRoute"
                 autowire="true"
                 autoconfigure="true">
            <argument type="service" id="KeszlerShippingPhoneRequirement\SalesChannel\RegisterRouteDecorator.inner" />
        </service>

        <service id="KeszlerShippingPhoneRequirement\Checkout\Cart\PhoneNumberRequiredCartValidator" autowire="true">
            <tag name="shopware.cart.validator" />
        </service>

        <service id="KeszlerShippingPhoneRequirement\Controller\CheckoutPhoneNumberController" public="true">
            <argument type="service" id="customer_address.repository" />
            <argument type="service" id="KeszlerShippingPhoneRequirement\Service\PhoneNumberValidator" />
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
        </service>
    </services>
</container>
